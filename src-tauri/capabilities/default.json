{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all editor windows (main + New Window w-*)",
  "windows": ["main", "w-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-title",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "dialog:default"
  ]
}
