<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Entitlements for the BUNDLED Node runtime (resources/lsp/node), signed
       separately from the app. Node uses V8 JIT and dlopen's native addons
       (e.g. fsevents.node) plus the language-server scripts; under the hardened
       runtime (required for notarization) these must be explicitly allowed or
       node crashes at launch. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
