{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maincode",
  "version": "0.1.3",
  "identifier": "com.morpheusdesk.maincode",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "beforeBundleCommand": "bash scripts/sign-lsp-resources.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Maincode",
        "width": 1200,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 800,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; connect-src ipc: http://ipc.localhost http://127.0.0.1:*; img-src 'self' data: https://avatars.githubusercontent.com; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": ["../resources/lsp/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Deadalus Systems (F77F7X4Q2W)",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/champ3oy/maincode/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5QjlFMTU0QTlDMUIyRTEKUldUaHNzR3BWT0c1K2N0bXAzR3dxUldGcU5RL2JYdStqdTVvV1BoVG5DMFdQOUJFa2N6Mjk5Z3AK"
    }
  }
}
